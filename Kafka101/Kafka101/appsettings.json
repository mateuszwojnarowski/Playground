{
  // ==========================================================================
  // appsettings.json - Kafka101 Configuration
  // ==========================================================================
  //
  // This file contains all configuration settings for the Kafka101 learning
  // project. Modify these values to match your Kafka environment.
  //
  // TO USE A DIFFERENT KAFKA SETUP:
  //   - Local Docker:        "localhost:9092" (default)
  //   - Multiple brokers:    "broker1:9092,broker2:9092,broker3:9092"
  //   - Confluent Cloud:     "pkc-xxxxx.region.provider.confluent.cloud:9092"
  //   - Amazon MSK:          "b-1.cluster.xxxxx.kafka.region.amazonaws.com:9092"

  "Kafka": {
    // BootstrapServers: Initial connection point(s) for the Kafka cluster.
    // These are used for cluster discovery, not necessarily all brokers.
    // For local development with Docker, use "localhost:9092"
    "BootstrapServers": "localhost:9092",

    // Default topic names for each complexity level
    "Topics": {
      "BeginnerDemo": "beginner-demo",
      "IntermediateOrders": "intermediate-orders",
      "AdvancedOrders": "advanced-orders",
      "ProcessedOrders": "processed-orders",
      "FailedOrders": "failed-orders",
      "PerfTest": "advanced-perf-test",
      "AuditLog": "audit-log"
    },

    // Producer defaults (can be overridden per-demo)
    "Producer": {
      "Acks": "All",
      "MessageTimeoutMs": 30000,
      "CompressionType": "Snappy",
      "LingerMs": 5,
      "BatchNumMessages": 1000
    },

    // Consumer defaults (can be overridden per-demo)
    "Consumer": {
      "AutoOffsetReset": "Earliest",
      "EnableAutoCommit": false,
      "SessionTimeoutMs": 30000,
      "MaxPollIntervalMs": 300000
    },

    // Security settings (for production use)
    // Uncomment and fill in for secured Kafka clusters
    "Security": {
      // "SecurityProtocol": "SaslSsl",
      // "SaslMechanism": "Plain",
      // "SaslUsername": "your-api-key",
      // "SaslPassword": "your-api-secret",
      // "SslCaLocation": "/path/to/ca-cert.pem"
    }
  },

  // Logging configuration
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
